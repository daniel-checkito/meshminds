      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const resp = $input.item.json;\nconst text = (resp.content && resp.content[0] && resp.content[0].text)\n  ? resp.content[0].text.trim()\n  : '';\n\nif (!text) throw new Error('Empty response from Claude');\n\nconst fenceMatch = text.match(/```(?:json)?\\s*([\\s\\S]*?)```/);\nconst clean = fenceMatch ? fenceMatch[1].trim() : text;\nconst start = clean.indexOf('{');\nconst end = clean.lastIndexOf('}');\n\nif (start === -1 || end <= start) {\n  throw new Error('No JSON object found in Claude response: ' + text.substring(0, 200));\n}\n\nlet result;\ntry {\n  result = JSON.parse(clean.slice(start, end + 1));\n} catch (e) {\n  throw new Error('JSON parse failed: ' + e.message + ' | Raw: ' + text.substring(0, 300));\n}\n\nreturn [{ json: result }];"
      },
